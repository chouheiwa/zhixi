{
  "name": "zhixi",
  "version": "1.0.1",
  "description": "知析 - 知乎致知计划收益智能分析工具",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:firefox": "yarn build && node scripts/build-firefox.mjs",
    "lint:firefox": "web-ext lint --source-dir=dist-firefox --ignore-files \"assets/antd-*.js\" \"assets/echarts-*.js\" \"assets/driver-*.js\"",
    "run:firefox": "web-ext run --source-dir=dist-firefox --start-url=about:debugging",
    "package:firefox": "web-ext build --source-dir=dist-firefox --artifacts-dir=web-ext-artifacts --overwrite-dest",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tensorflow/tfjs": "^4.22.0",
    "antd": "^6.3.4",
    "dexie": "^4.0.11",
    "driver.js": "^1.4.0",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "ml-cart": "^2.1.1",
    "ml-random-forest": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^16.6.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "web-ext": "^10.1.0"
  }
}
